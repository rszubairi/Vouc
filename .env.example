# ─── Convex ──────────────────────────────────────────────────────────────────
# Get this from: https://dashboard.convex.dev → your project → Settings
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# For mobile (set in apps/mobile/.env or app.json extra)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ─── Auth (Convex Auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWKS_PRIVATE_KEY=your-jwks-private-key
JWT_PRIVATE_KEY=your-jwt-private-key
SITE_URL=https://your-admin.vercel.app

# ─── Email (OTP / account confirmation) ──────────────────────────────────────
# Used by @convex-dev/auth ResendOTP provider
RESEND_API_KEY=re_your_resend_api_key
AUTH_RESEND_KEY=re_your_resend_api_key

# ─── Push Notifications ───────────────────────────────────────────────────────
# Firebase Admin SDK credentials (for server-side FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
